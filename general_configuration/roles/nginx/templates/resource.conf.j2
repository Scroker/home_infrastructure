server {
    listen       {{ nginx_http_port }};
    listen       [::]:{{ nginx_http_port }};
    server_name  {{ item.server_fqdn }};
    return 301 https://$server_name$request_uri;
}

server {

    {% if item.upstreams is defined %}
    upstream {{ item.server_fqdn }}_upstream {
    {% for upstream in item.upstreams %}
        server {{ upstream }}:{{ item.server_port }};
    {% endfor %}
    }
    {% endif %}

    listen       {{ nginx_https_port }} ssl;
    listen       [::]:{{ nginx_https_port }} ssl;
    http2        on;
    server_name  {{ item.server_fqdn }};

    ssl_certificate {{ nginx_config.ssl_certificate }};
    ssl_certificate_key {{ nginx_config.ssl_certificate_key }};
    ssl_session_cache {{ nginx_config.ssl_session_cache }};
    ssl_session_timeout {{ nginx_config.ssl_session_timeout }};
    ssl_ciphers {{ nginx_config.ssl_ciphers }};
    ssl_prefer_server_ciphers {{ nginx_config.ssl_prefer_server_ciphers }};

    location / {
{% if item.upstreams is defined %}
            proxy_pass {{ item.server_fqdn }}_upstream;
{% else %}
            proxy_pass {{ item.proxy_fqdn }};
{% endif %}
            proxy_ssl_verify off;
            proxy_set_header Host $host;
            proxy_http_version 1.1;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header Upgrade $http_upgrade;
            proxy_set_header Connection "upgrade";
    }
}

# Load dynamic modules. See /usr/share/doc/nginx/README.dynamic.
include /usr/share/nginx/modules/*.conf;

events {
    worker_connections 1024;
}

http {
    log_format  main  '$remote_addr - $remote_user [$time_local] "$request" '
                      '$status $body_bytes_sent "$http_referer" '
                      '"$http_user_agent" "$http_x_forwarded_for"';

    access_log  /var/log/nginx/access.log  main;

    sendfile            on;
    tcp_nopush          on;
    keepalive_timeout   65;
    types_hash_max_size 4096;

    include             /etc/nginx/mime.types;
    default_type        application/octet-stream;

    # Load modular configuration files from the /etc/nginx/conf.d directory.
    # See http://nginx.org/en/docs/ngx_core_module.html#include
    # for more information.
    include /etc/nginx/conf.d/*.conf;

    server {
        listen       {{ nginx_http_port }};
        listen       [::]:{{ nginx_http_port }};
        server_name  {{ nginx_server_fqdn }};
        return 301 https://$server_name$request_uri;
    }

    server {
        listen       {{ nginx_https_port }} ssl;
        listen       [::]:{{ nginx_https_port }} ssl;
        http2        on;
        server_name  {{ nginx_server_fqdn }};
        root         /usr/share/nginx/html;
        
        ssl_certificate {{ nginx_config.ssl_certificate }};
        ssl_certificate_key {{ nginx_config.ssl_certificate_key }};
        ssl_session_cache {{ nginx_config.ssl_session_cache }};
        ssl_session_timeout {{ nginx_config.ssl_session_timeout }};
        ssl_ciphers {{ nginx_config.ssl_ciphers }};
        ssl_prefer_server_ciphers {{ nginx_config.ssl_prefer_server_ciphers }};
    }

    # Load configuration files for the default server block.
    include /etc/nginx/default.d/*.conf;
}

stream {

    upstream nut_backend {
        server 127.0.0.1:3493;
    }

    server {
        listen 4493;
        proxy_pass nut_backend;
    }
}
[Unit]
Description={{ item.description | default('Podman Container ' + item.container_name) }}
After=network-online.target
Wants=network-online.target

[Service]
{% if item.user is defined %}
User={{ item.user }}
{% endif %}
{% if item.group is defined %}
Group={{ item.group }}
{% endif %}
Restart=always
ExecStartPre=-/usr/bin/podman rm -f {{ item.container_name }}
ExecStart=/usr/bin/podman run \
  --name {{ item.container_name }} \
{% if item.privileged is defined %}
  --privileged \
  --security-opt label=disable \
{% endif %}
{% if item.network is defined %}
  --net={{ item.network }} \
{% endif %}
{% if item.portmaps is defined %}
{% for portmap in item.portmaps %}
  -p {{ portmap }} \
{% endfor %}
{% endif %}
{% if item.volumes is defined %}
{% for volume in item.volumes %}
  -v {{ volume }} \
{% endfor %}
{% endif %}
{% if item.devices is defined %}
{% for device in item.devices %}
  --device {{ device }} \
{% endfor %}
{% endif %}
{% if item.environment is defined %}
{% for env_var in item.environment %}
  -e {{ env_var }} \
{% endfor %}
{% endif %}
{% if item.restart is defined %}
  --restart {{ item.restart }} \
{% endif %}
{% if item.exec is defined %}
  {{ item.exec }}
{% endif %}
  {{ item.image }}
  

ExecStop=/usr/bin/podman stop -t 10 {{ item.container_name }}
ExecStopPost=-/usr/bin/podman rm -f {{ item.container_name }}
Type=simple

{% if item.wanted_by is defined %}
[Install]
WantedBy={{ item.wanted_by }}
{% endif %}